PORT=4000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cruzo_ai"
REDIS_URL="redis://localhost:6379"
OPENAI_API_KEY=""
OPENAI_IMAGE_MODEL="gpt-image-1"
IMAGE_PROVIDER="openai"
FAL_API_KEY=""
FAL_IMAGE_MODEL="fal-ai/flux/dev"
GOOGLE_API_KEY=""
GEMINI_TEXT_MODEL="gemini-2.5-flash"
GEMINI_LIVE_MODEL="gemini-live-2.5-flash-preview"
GCP_PROJECT_ID="greeting-ai-agent"
GCS_BUCKET=""
LIVE_SESSION_TTL_SEC=3600
USE_MOCK_LIVE_AGENT=true
USE_MOCK_STORAGE_PROVIDER=true
R2_ENDPOINT=""
R2_REGION="auto"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="cruzo-ai-assets"
RATE_LIMIT_SESSION_PER_MINUTE=5
RATE_LIMIT_IP_PER_HOUR=30
ENABLE_PROMPT_MODERATION=true
DEFAULT_FREE_CREDITS=20
QUEUE_NAME_GENERATE_IMAGE=generate-image
ASSETS_SIGNED_URL_TTL_SECONDS=86400
USE_MOCK_IMAGE_PROVIDER=true

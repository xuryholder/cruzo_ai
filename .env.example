# Copy to .env and fill with your own values
GOOGLE_API_KEY=
OPENAI_API_KEY=
FAL_API_KEY=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=

USE_MOCK_LIVE_AGENT=true
USE_MOCK_IMAGE_PROVIDER=true
USE_MOCK_STORAGE_PROVIDER=true
